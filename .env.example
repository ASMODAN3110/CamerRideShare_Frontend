# En dev, laisser vide pour utiliser le proxy Vite vers localhost:3000 :
# /auth, /users, /admin, /transactions, /payments, /incidents, /invitations, /motos
# En prod (Vercel), URL complète du backend NestJS
VITE_API_URL=

# Docker uniquement : cible du proxy Vite (host machine depuis le conteneur)
# VITE_API_PROXY_TARGET=http://host.docker.internal:3000
